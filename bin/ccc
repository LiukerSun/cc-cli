#!/bin/bash

VERSION_FILE="$HOME/.cc-cli/VERSION"
if [ -f "$VERSION_FILE" ]; then
    CC_VERSION=$(cat "$VERSION_FILE" | tr -d '[:space:]')
else
    CC_VERSION="unknown"
fi

detect_platform() {
    case "$(uname -s)" in
        Darwin*)    echo "macos" ;;
        Linux*)     echo "linux" ;;
        MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
        *)          echo "unknown" ;;
    esac
}

PLATFORM=$(detect_platform)
CONFIG_FILE="$HOME/.cc-config.json"
ENV_FILE="/tmp/cc-model-env.sh"
CLAUDE_SETTINGS_FILE="$HOME/.claude/settings.json"
CODEX_CONFIG_FILE="$HOME/.codex/config.toml"
CODEX_AUTH_FILE="$HOME/.codex/auth.json"

# Terminal control (cross-platform)
hide_cursor() { printf "\033[?25l"; }
show_cursor() { printf "\033[?25h"; }
clear_screen() { 
    case "$PLATFORM" in
        windows) printf "\033[2J\033[H" ;;
        *) printf "\033[2J\033[H" ;;
    esac
}
move_cursor() { printf "\033[$1;$2H"; }

usage() {
    echo "Usage: ccc [OPTIONS] [MODEL_INDEX] [-- CLI_ARGS...]"
    echo ""
    echo "Start the configured AI CLI with the selected model configuration."
    echo ""
    echo "Options:"
    echo "  -y, --bypass      Enable bypass permissions"
    echo "  -e, --env         Only set environment variables"
    echo "  -l, --list        List all available models"
    echo "  -c, --current     Show current model"
    echo "  --edit            Edit configuration file"
    echo "  -a, --add         Add a new model configuration"
    echo "  -d, --delete N    Delete model #N"
    echo "  -s, --show        Show API keys (partially hidden)"
    echo "  --validate        Validate and repair config file"
    echo "  -U, --upgrade     Upgrade to latest version"
    echo "  -V, --version     Show version"
    echo "  --uninstall       Uninstall cc-cli"
    echo "  -h, --help        Show this help message"
    echo ""
    echo "Note: When the selected command is 'claude', this command also updates"
    echo "      ~/.claude/settings.json so team subagents use the same model."
    echo ""
    echo "Examples:"
    echo "  ccc              Interactive model selection (use arrow keys)"
    echo "  ccc 2            Start the configured CLI with model #2"
    echo "  ccc -y 3         Start the configured CLI with model #3 and bypass permissions"
    echo "  ccc -E           Edit configuration file"
    echo "  ccc -a           Add a new model"
    echo "  ccc -d 2         Delete model #2"
    echo "  ccc -s           Show API keys"
    echo "  ccc -U           Upgrade to latest version"
}

show_version() {
    echo "ccc version $CC_VERSION"
}

uninstall_cc() {
    local install_script="$HOME/.cc-cli/install.sh"
    
    if [ -f "$install_script" ]; then
        bash "$install_script" --uninstall "$@"
    else
        echo "Install script not found, running from remote..."
        echo ""
        curl -fsSL https://raw.githubusercontent.com/LiukerSun/cc-cli/main/install.sh | bash -s -- --uninstall "$@"
    fi
}

check_latest_version() {
    local latest_version
    latest_version=$(curl -fsSL "https://raw.githubusercontent.com/LiukerSun/cc-cli/main/VERSION" 2>/dev/null | tr -d '[:space:]')
    
    if [ -z "$latest_version" ]; then
        echo "Error: Failed to check latest version" >&2
        return 1
    fi
    
    echo "$latest_version"
}

compare_versions() {
    local v1="$1"
    local v2="$2"
    
    if [ "$v1" = "$v2" ]; then
        echo "equal"
        return 0
    fi
    
    local IFS=.
    local i ver1=($v1) ver2=($v2)
    
    for ((i=0; i<${#ver1[@]}; i++)); do
        if [ -z "${ver2[i]}" ]; then
            ver2[i]=0
        fi
        
        if ((10#${ver1[i]} > 10#${ver2[i]})); then
            echo "greater"
            return 0
        fi
        
        if ((10#${ver1[i]} < 10#${ver2[i]})); then
            echo "less"
            return 0
        fi
    done
    
    echo "less"
}

upgrade() {
    echo "═══════════════════════════════════════"
    echo "  CC-CLI Updater"
    echo "═══════════════════════════════════════"
    echo ""
    
    echo "Checking latest version..."
    local latest_version
    latest_version=$(check_latest_version)
    
    if [ $? -ne 0 ]; then
        exit 1
    fi
    
    echo "Current version: $CC_VERSION"
    echo "Latest version:  $latest_version"
    echo ""
    
    local comparison
    comparison=$(compare_versions "$CC_VERSION" "$latest_version")
    
    if [ "$comparison" = "equal" ]; then
        echo "✓ Already running the latest version!"
        exit 0
    elif [ "$comparison" = "greater" ]; then
        echo "⚠ You're running a newer version than the latest release"
        exit 0
    fi
    
    echo "Upgrading from $CC_VERSION to $latest_version..."
    echo ""
    
    local tmp_dir
    tmp_dir=$(mktemp -d)
    local script_url="https://raw.githubusercontent.com/LiukerSun/cc-cli/main/bin/ccc"
    local version_url="https://raw.githubusercontent.com/LiukerSun/cc-cli/main/VERSION"

    echo "Downloading latest version..."

    if ! curl -fsSL "$script_url" -o "$tmp_dir/ccc" 2>/dev/null; then
        echo "Error: Failed to download script" >&2
        rm -rf "$tmp_dir"
        exit 1
    fi
    
    if ! curl -fsSL "$version_url" -o "$tmp_dir/VERSION" 2>/dev/null; then
        echo "Error: Failed to download VERSION file" >&2
        rm -rf "$tmp_dir"
        exit 1
    fi
    
    local install_dir="$HOME/.cc-cli"
    local bin_dir="$HOME/bin"
    
    mkdir -p "$install_dir"
    mkdir -p "$bin_dir"
    
    chmod +x "$tmp_dir/ccc"

    if ! cp "$tmp_dir/ccc" "$bin_dir/ccc"; then
        echo "Error: Failed to install script" >&2
        rm -rf "$tmp_dir"
        exit 1
    fi
    
    if ! cp "$tmp_dir/VERSION" "$install_dir/VERSION"; then
        echo "Error: Failed to install VERSION file" >&2
        rm -rf "$tmp_dir"
        exit 1
    fi
    
    rm -rf "$tmp_dir"
    
    # Verify PATH includes ~/bin
    if [[ ":$PATH:" != *":$HOME/bin:"* ]]; then
        echo ""
        echo "⚠ Warning: ~/bin is not in your PATH"
        echo "  Please add it to your shell configuration:"
        echo "  echo 'export PATH=\"\$HOME/bin:\$PATH\"' >> ~/.bashrc"
        echo "  source ~/.bashrc"
    fi
    
    # Migrate from old 'cc' command name
    if [ -f "$bin_dir/cc" ] && head -1 "$bin_dir/cc" | grep -q "bash"; then
        rm -f "$bin_dir/cc"
        echo "✓ Removed old 'cc' command (now use 'ccc')"
    fi

    echo ""
    echo "═══════════════════════════════════════"
    echo "  ✓ Upgrade Complete!"
    echo "═══════════════════════════════════════"
    echo ""
    echo "Upgraded from $CC_VERSION to $latest_version"
    echo ""
    echo "Run 'ccc --version' to verify the upgrade"
}

list_models() {
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "Error: Config file not found at $CONFIG_FILE"
        exit 1
    fi
    
    local current_model=""
    if [ -f "$ENV_FILE" ]; then
        current_model=$(grep "^# Model:" "$ENV_FILE" | sed 's/# Model: //')
    fi
    
    echo "═══════════════════════════════════════"
    echo "  Available AI Models"
    echo "═══════════════════════════════════════"
    echo ""
    
    local index=1
    while IFS= read -r line; do
        name=$(echo "$line" | sed 's/.*"name": *"\([^"]*\)".*/\1/')
        if [ "$name" = "$current_model" ]; then
            printf "  \033[0;32m➜ %d) %s \033[0m\033[0;90m(current)\033[0m\n" "$index" "$name"
        else
            printf "    %d) %s\n" "$index" "$name"
        fi
        ((index++))
    done < <(grep '"name"' "$CONFIG_FILE")
    echo ""
    echo "───────────────────────────────────────"
}

get_models_array() {
    grep '"name"' "$CONFIG_FILE" | sed 's/.*"name": *"\([^"]*\)".*/\1/'
}

draw_menu() {
    local selected=$1
    local current_model=$2
    local models=("${@:3}")
    local count=${#models[@]}
    
    clear_screen >&2
    hide_cursor >&2
    
    echo "═══════════════════════════════════════" >&2
    echo "  Available AI Models" >&2
    echo "═══════════════════════════════════════" >&2
    echo "" >&2
    
    local i=1
    for model in "${models[@]}"; do
        if [ $i -eq $selected ]; then
            if [ "$model" = "$current_model" ]; then
                printf "  \033[44m\033[1;37m➜ %d) %-25s\033[0m \033[0;90m(current)\033[0m\n" "$i" "$model" >&2
            else
                printf "  \033[44m\033[1;37m➜ %d) %-25s\033[0m\n" "$i" "$model" >&2
            fi
        else
            if [ "$model" = "$current_model" ]; then
                printf "  \033[0;32m➜ %d) %-25s\033[0m \033[0;90m(current)\033[0m\n" "$i" "$model" >&2
            else
                printf "    %d) %s\n" "$i" "$model" >&2
            fi
        fi
        ((i++))
    done
    
    echo "" >&2
    echo "───────────────────────────────────────" >&2
    echo "" >&2
    printf "\033[0;90m  ↑↓ Navigate  •  Enter Select  •  q Exit\033[0m" >&2
}

select_interactive() {
    local models=()
    while IFS= read -r line; do
        models+=("$line")
    done < <(get_models_array)
    
    local count=${#models[@]}
    if [ $count -eq 0 ]; then
        echo "═══════════════════════════════════════"
        echo "  No Models Configured"
        echo "═══════════════════════════════════════"
        echo ""
        echo "Please add a model first:"
        echo "  ccc -a        Add a new model"
        echo ""
        exit 0
    fi
    
    local current_model=""
    if [ -f "$ENV_FILE" ]; then
        current_model=$(grep "^# Model:" "$ENV_FILE" | sed 's/# Model: //')
    fi
    
    # Default selection: current model or first
    local selected=1
    if [ -n "$current_model" ]; then
        for i in "${!models[@]}"; do
            if [ "${models[$i]}" = "$current_model" ]; then
                selected=$((i + 1))
                break
            fi
        done
    fi
    
    draw_menu $selected "$current_model" "${models[@]}"
    
    # Read keyboard input
    while true; do
        read -rsn1 key
        case "$key" in
            $'\x1b')
                # Try to read arrow key sequence (compatible with bash 3.2)
                read -rsn1 -t 1 bracket
                read -rsn1 -t 1 letter
                case "$bracket$letter" in
                    '[A')  # Up arrow
                        ((selected--))
                        [ $selected -lt 1 ] && selected=$count
                        draw_menu $selected "$current_model" "${models[@]}"
                        ;;
                    '[B')  # Down arrow
                        ((selected++))
                        [ $selected -gt $count ] && selected=1
                        draw_menu $selected "$current_model" "${models[@]}"
                        ;;
                    '')
                        # ESC pressed (no additional characters)
                        echo "" >&2
                        show_cursor >&2
                        exit 1
                        ;;
                esac
                ;;
            '')  # Enter
                echo "" >&2
                show_cursor >&2
                echo $selected
                return 0
                ;;
            q|Q)
                echo "" >&2
                show_cursor >&2
                exit 1
                ;;
            [1-9])
                if [ $key -le $count ]; then
                    selected=$key
                    draw_menu $selected "$current_model" "${models[@]}"
                fi
                ;;
        esac
    done
}

get_model_count() {
    if command -v jq &> /dev/null; then
        jq 'length' "$CONFIG_FILE"
        return
    fi

    grep -c '"name"' "$CONFIG_FILE"
}

get_model_name() {
    local index=$1
    if command -v jq &> /dev/null; then
        jq -r ".[$((index - 1))].name // empty" "$CONFIG_FILE"
        return
    fi

    sed -n 's/.*"name": *"\([^"]*\)".*/\1/p' "$CONFIG_FILE" | sed -n "${index}p"
}

get_model_command() {
    local model_index=$1
    if command -v jq &> /dev/null; then
        jq -r ".[$((model_index - 1))].command // \"claude\"" "$CONFIG_FILE"
        return
    fi

    local start_line=$(grep -n '"name"' "$CONFIG_FILE" | sed -n "${model_index}p" | cut -d: -f1)
    local value=$(awk -v start="$start_line" '
        NR < start { next }
        /"env"/ { exit }
        /"command":/ {
            gsub(/.*"command": *"/, "");
            gsub(/".*/, "");
            print;
            exit
        }
        NR > start && /}/ { exit }
    ' "$CONFIG_FILE")

    if [ -n "$value" ]; then
        echo "$value"
    else
        echo "claude"
    fi
}

get_command_base_url_key() {
    local command_name="$1"
    if [ "$command_name" = "codex" ]; then
        echo "OPENAI_BASE_URL"
    else
        echo "ANTHROPIC_BASE_URL"
    fi
}

get_command_api_key_key() {
    local command_name="$1"
    if [ "$command_name" = "codex" ]; then
        echo "OPENAI_API_KEY"
    else
        echo "ANTHROPIC_AUTH_TOKEN"
    fi
}

get_command_main_model_key() {
    local command_name="$1"
    if [ "$command_name" = "codex" ]; then
        echo "OPENAI_MODEL"
    else
        echo "ANTHROPIC_MODEL"
    fi
}

get_command_fast_model_key() {
    local command_name="$1"
    if [ "$command_name" = "codex" ]; then
        echo "OPENAI_SMALL_FAST_MODEL"
    else
        echo "ANTHROPIC_SMALL_FAST_MODEL"
    fi
}

get_command_bypass_flag() {
    local command_name="$1"
    if [ "$command_name" = "codex" ]; then
        echo "--dangerously-bypass-approvals-and-sandbox"
    else
        echo "--dangerously-skip-permissions"
    fi
}

normalize_codex_base_url() {
    local base_url="$1"
    local trimmed="${base_url%/}"

    if [[ "$trimmed" == */v1 ]]; then
        echo "$trimmed"
    elif [[ "$trimmed" == */v1/models ]]; then
        echo "${trimmed%/models}"
    elif [[ "$trimmed" == */models ]]; then
        echo "${trimmed%/models}/v1"
    elif [[ "$trimmed" == */responses ]]; then
        echo "${trimmed%/responses}/v1"
    else
        echo "$trimmed/v1"
    fi
}

get_env_vars() {
    local model_index=$1
    if command -v jq &> /dev/null; then
        jq -r ".[$((model_index - 1))].env // {} | to_entries[] | \"\(.key)=\(.value | @sh)\"" "$CONFIG_FILE"
        return
    fi

    # Extract env vars for selected model using awk
    local start_line=$(grep -n '"name"' "$CONFIG_FILE" | sed -n "${model_index}p" | cut -d: -f1)
    local env_block=$(awk -v start="$start_line" '
        NR >= start && /"env"/ { in_env=1 }
        in_env && /}/ { print; exit }
        in_env { print }
    ' "$CONFIG_FILE")

    # Output export statements
    echo "$env_block" | grep -E '^\s*"[A-Z_]+":' | while read -r line; do
        key=$(echo "$line" | sed 's/.*"\([A-Z_]*\)":.*/\1/')
        value=$(echo "$line" | sed 's/.*": *"\([^"]*\)".*/\1/')
        echo "$key=\"$value\""
    done
}

get_model_env_value() {
    local model_index=$1
    local key_name=$2
    if command -v jq &> /dev/null; then
        jq -r --arg key_name "$key_name" ".[$((model_index - 1))].env[\$key_name] // empty" "$CONFIG_FILE"
        return
    fi

    local start_line=$(grep -n '"name"' "$CONFIG_FILE" | sed -n "${model_index}p" | cut -d: -f1)
    local value=$(awk -v start="$start_line" -v key="$key_name" '
        NR >= start && /"env"/ { in_env=1 }
        in_env && $0 ~ "\"" key "\":" {
            gsub(/.*": *"/, "");
            gsub(/".*/, "");
            print;
            exit
        }
        in_env && /}/ { exit }
    ' "$CONFIG_FILE")

    echo "$value"
}

run_with_model() {
    local model_index=$1
    local skip_perm=$2
    local only_env=$3
    shift 3
    local cli_args=("$@")

    local count=$(get_model_count)

    if [ -z "$model_index" ]; then
        trap 'show_cursor' EXIT
        local selection=$(select_interactive)
        if [ -z "$selection" ]; then
            exit 1
        fi
        model_index=$selection
        trap - EXIT
    fi

    case "$model_index" in
        ''|*[!0-9]*)
            echo "Error: Invalid model index. Must be between 1 and $count"
            exit 1
            ;;
    esac

    if [ "$model_index" -lt 1 ] || [ "$model_index" -gt "$count" ]; then
        echo "Error: Invalid model index. Must be between 1 and $count"
        exit 1
    fi

    local model_name=$(get_model_name "$model_index")
    local command_name=$(get_model_command "$model_index")
    local base_url_key=$(get_command_base_url_key "$command_name")
    local api_key_key=$(get_command_api_key_key "$command_name")
    local main_model_key=$(get_command_main_model_key "$command_name")
    local fast_model_key=$(get_command_fast_model_key "$command_name")
    local base_url=$(get_model_env_value "$model_index" "$base_url_key")
    local api_key=$(get_model_env_value "$model_index" "$api_key_key")
    local main_model=$(get_model_env_value "$model_index" "$main_model_key")
    local fast_model=$(get_model_env_value "$model_index" "$fast_model_key")

    if [ "$command_name" = "codex" ]; then
        base_url=$(normalize_codex_base_url "$base_url")
    fi

    # Default fast model to main model if not set
    if [ -z "$fast_model" ]; then
        fast_model="$main_model"
    fi

    echo "✓ Using model: $model_name"
    echo "✓ Using command: $command_name"

    if [ "$skip_perm" = "true" ]; then
        printf "✓ \033[0;33mBypass permissions enabled\033[0m\n"
    fi

    echo "───────────────────────────────────────"

    if [ "$command_name" != "codex" ]; then
        update_claude_settings "$main_model" "$fast_model"
        echo "✓ Updated Claude settings (for team subagent)"
    else
        update_codex_config "$base_url" "$main_model"
        update_codex_auth "$api_key"
        echo "✓ Updated Codex config and auth"
    fi

    # Build environment variables
    local env_vars=$(get_env_vars "$model_index")

    # Create env file for reference
    echo "# Generated by ccc command" > "$ENV_FILE"
    echo "# Model: $model_name" >> "$ENV_FILE"

    while IFS= read -r env_line; do
        [ -z "$env_line" ] && continue
        if [ "$command_name" = "codex" ] && [[ "$env_line" == OPENAI_BASE_URL=* ]]; then
            continue
        fi
        echo "export $env_line" >> "$ENV_FILE"
    done <<< "$env_vars"

    if [ "$skip_perm" = "true" ] && [ "$command_name" != "codex" ]; then
        echo "export CLAUDE_SKIP_PERMISSIONS=1" >> "$ENV_FILE"
        echo "export IS_SANDBOX=1" >> "$ENV_FILE"
    fi

    if [ "$command_name" != "codex" ]; then
        # Add CLAUDE_CODE_MODEL environment variables for subagent support
        echo "export CLAUDE_CODE_MODEL=\"$main_model\"" >> "$ENV_FILE"
        echo "export CLAUDE_CODE_SMALL_MODEL=\"$fast_model\"" >> "$ENV_FILE"
        echo "export CLAUDE_CODE_SUBAGENT_MODEL=\"$main_model\"" >> "$ENV_FILE"
    fi

    if [ "$only_env" = "true" ]; then
        echo ""
        echo "Environment variables saved to: $ENV_FILE"
        echo "Run: source $ENV_FILE"
        exit 0
    fi

    # Source env file and execute the configured CLI
    source "$ENV_FILE"
    local exec_args=("${cli_args[@]}")
    if [ "$skip_perm" = "true" ]; then
        exec_args=("$(get_command_bypass_flag "$command_name")" "${exec_args[@]}")
    fi

    if ! command -v "$command_name" >/dev/null 2>&1; then
        echo "Error: $command_name CLI not found"
        exit 1
    fi

    exec "$command_name" "${exec_args[@]}"
}

show_current() {
    if [ -f "$ENV_FILE" ]; then
        grep "^# Model:" "$ENV_FILE" | sed 's/# Model: /Current model: /'
        if grep -q "CLAUDE_SKIP_PERMISSIONS" "$ENV_FILE"; then
            echo "Bypass permissions: enabled"
        fi
    else
        echo "No model currently selected in this session"
    fi
}

edit_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "Error: Config file not found at $CONFIG_FILE"
        exit 1
    fi
    
    local editor="${EDITOR:-vim}"
    echo "Opening config file with $editor..."
    echo "File: $CONFIG_FILE"
    echo ""
    $editor "$CONFIG_FILE"
}

validate_config() {
    echo "═══════════════════════════════════════"
    echo "  Config File Validator"
    echo "═══════════════════════════════════════"
    echo ""
    echo "File: $CONFIG_FILE"
    echo ""
    
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "⚠ Config file does not exist"
        echo ""
        echo "Creating empty config file..."
        echo "[]" > "$CONFIG_FILE"
        echo "✓ Empty config file created"
        return
    fi
    
    # Check if valid JSON
    if command -v jq &> /dev/null; then
        if ! jq empty "$CONFIG_FILE" 2>/dev/null; then
            echo "✗ Config file is not valid JSON"
            echo ""
            echo "Please fix manually: ccc --edit"
            exit 1
        fi
        echo "✓ JSON syntax is valid"
        
        local valid_count=$(jq '[.[] | select(
            .name and .env and
            ((.command // "claude") as $command |
                if $command == "codex" then
                    .env.OPENAI_BASE_URL and .env.OPENAI_API_KEY and .env.OPENAI_MODEL
                else
                    .env.ANTHROPIC_BASE_URL and .env.ANTHROPIC_AUTH_TOKEN and .env.ANTHROPIC_MODEL
                end
            )
        )] | length' "$CONFIG_FILE")
        local total_count=$(jq 'length' "$CONFIG_FILE")
        local invalid_count=$((total_count - valid_count))
        
        echo ""
        echo "Valid entries:   $valid_count"
        echo "Invalid entries: $invalid_count"
        
        if [ "$invalid_count" -gt 0 ]; then
            echo ""
            echo "Repairing config file..."
            jq '[.[] | select(
                .name and .env and
                ((.command // "claude") as $command |
                    if $command == "codex" then
                        .env.OPENAI_BASE_URL and .env.OPENAI_API_KEY and .env.OPENAI_MODEL
                    else
                        .env.ANTHROPIC_BASE_URL and .env.ANTHROPIC_AUTH_TOKEN and .env.ANTHROPIC_MODEL
                    end
                )
            )]' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp"
            mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
            echo "✓ Removed $invalid_count invalid entries"
        fi
    else
        # Fallback without jq - basic check
        if grep -q '"name"' "$CONFIG_FILE" && grep -q '"env"' "$CONFIG_FILE"; then
            echo "✓ Config file appears valid (basic check)"
        else
            echo "✗ Config file appears invalid"
        fi
    fi
    
    echo ""
    echo "Remaining models:"
    list_models
}

add_model() {
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "[]" > "$CONFIG_FILE"
    fi
    
    echo "═══════════════════════════════════════"
    echo "  Add New Model Configuration"
    echo "═══════════════════════════════════════"
    echo ""
    echo "Select provider:"
    echo "  1) ZHIPU AI - Claude-compatible provider"
    echo "  2) Alibaba Coding Plan - Claude-compatible provider"
    echo "  3) OpenAI Codex"
    echo "  4) Manual input (Claude-compatible)"
    echo ""
    read -p "Choice [1-4]: " provider_choice

    if [ "$provider_choice" = "1" ]; then
        add_zhipu_model
    elif [ "$provider_choice" = "2" ]; then
        add_alibaba_coding_plan
    elif [ "$provider_choice" = "3" ]; then
        add_codex_model
    elif [ "$provider_choice" = "4" ]; then
        add_manual_model "claude"
    else
        echo "Error: Invalid choice"
        exit 1
    fi
}

get_supported_codex_models() {
    cat <<EOF
gpt-5.4
gpt-5.4-mini
gpt-5.3-codex
gpt-5.3-codex-spark
gpt-5.2-codex
gpt-5.2
gpt-5.1-codex-max
gpt-5.1
gpt-5.1-codex
gpt-5
gpt-5-codex
gpt-5-codex-mini
EOF
}

add_codex_model() {
    echo ""
    echo "═══════════════════════════════════════"
    echo "  OpenAI-Compatible Codex Configuration"
    echo "═══════════════════════════════════════"
    echo ""

    read -p "API Base URL (e.g., https://api.openai.com/v1): " base_url
    [ -z "$base_url" ] && echo "Error: Base URL is required" && exit 1

    read -p "API Key: " api_key
    [ -z "$api_key" ] && echo "Error: API Key is required" && exit 1

    echo ""
    echo "Using built-in OpenAI/Codex model list"
    echo ""

    local models=()
    while IFS= read -r model; do
        [ -n "$model" ] && models+=("$model")
    done <<< "$(get_supported_codex_models)"
    models+=("Custom model ID")

    local count=${#models[@]}
    if [ "$count" -eq 0 ]; then
        echo "Error: No models available"
        exit 1
    fi

    echo "Available Models:"
    echo ""
    local i=1
    for model in "${models[@]}"; do
        printf "  %2d) %s\n" "$i" "$model"
        ((i++))
    done
    echo ""

    read -p "Select model [1-$count]: " main_idx
    if ! [[ "$main_idx" =~ ^[0-9]+$ ]] || [ "$main_idx" -lt 1 ] || [ "$main_idx" -gt "$count" ]; then
        echo "Error: Invalid selection"
        exit 1
    fi
    local main_model="${models[$main_idx-1]}"
    if [ "$main_model" = "Custom model ID" ]; then
        read -p "Custom model ID: " main_model
        [ -z "$main_model" ] && echo "Error: Model ID is required" && exit 1
    fi

    read -p "Display name (default: Codex ($main_model)): " model_name
    [ -z "$model_name" ] && model_name="Codex ($main_model)"

    save_model_config "$model_name" "$(normalize_codex_base_url "$base_url")" "$api_key" "$main_model" "" "codex"
}

add_zhipu_model() {
    echo ""
    echo "═══════════════════════════════════════"
    echo "  ZHIPU AI Configuration"
    echo "═══════════════════════════════════════"
    echo ""
    read -p "API Key: " api_key
    [ -z "$api_key" ] && echo "Error: API Key is required" && exit 1
    
    echo ""
    printf "Fetching models from ZHIPU AI"
    
    local models_url="https://open.bigmodel.cn/api/paas/v4/models"
    local response
    response=$(curl -s -w "\n%{http_code}" -H "Authorization: Bearer $api_key" "$models_url" 2>/dev/null)
    local http_code=$(echo "$response" | tail -n1)
    local body=$(echo "$response" | sed '$d')
    
    if [ "$http_code" != "200" ]; then
        echo ""
        echo "Error: Failed to fetch models (HTTP $http_code)"
        echo "Response: $body"
        exit 1
    fi
    
    echo " Done!"
    echo ""
    
    local model_list
    model_list=$(echo "$body" | grep -o '"id":"[^"]*"' | sed 's/"id":"//;s/"$//' | sort)
    
    if [ -z "$model_list" ]; then
        echo "Error: No models found in response"
        exit 1
    fi
    
    local models=()
    while IFS= read -r model; do
        models+=("$model")
    done <<< "$model_list"
    
    local count=${#models[@]}
    
    echo "Available Models:"
    echo ""
    local i=1
    for model in "${models[@]}"; do
        printf "  %2d) %s\n" "$i" "$model"
        ((i++))
    done
    echo ""
    
    read -p "Select main model [1-$count]: " main_idx
    if ! [[ "$main_idx" =~ ^[0-9]+$ ]] || [ "$main_idx" -lt 1 ] || [ "$main_idx" -gt "$count" ]; then
        echo "Error: Invalid selection"
        exit 1
    fi
    local main_model="${models[$main_idx-1]}"
    
    read -p "Select fast model [1-$count] (default: same as main): " fast_idx
    local fast_model
    if [ -z "$fast_idx" ]; then
        fast_model="$main_model"
    elif [[ "$fast_idx" =~ ^[0-9]+$ ]] && [ "$fast_idx" -ge 1 ] && [ "$fast_idx" -le "$count" ]; then
        fast_model="${models[$fast_idx-1]}"
    else
        echo "Error: Invalid selection"
        exit 1
    fi
    
    local model_name="ZHIPU ($main_model)"

    save_model_config "$model_name" "https://open.bigmodel.cn/api/anthropic" "$api_key" "$main_model" "$fast_model"
}

add_alibaba_coding_plan() {
    echo ""
    echo "═══════════════════════════════════════"
    echo "  Alibaba Coding Plan Configuration"
    echo "═══════════════════════════════════════"
    echo ""
    read -p "API Key: " api_key
    [ -z "$api_key" ] && echo "Error: API Key is required" && exit 1

    echo ""
    printf "Fetching models from Alibaba Coding Plan"

    # Alibaba DashScope models endpoint
    local models_url="https://dashscope.aliyuncs.com/api/v1/models"
    local response
    response=$(curl -s -w "\n%{http_code}" -H "Authorization: Bearer $api_key" "$models_url" 2>/dev/null)
    local http_code=$(echo "$response" | tail -n1)
    local body=$(echo "$response" | sed '$d')

    local model_list=""

    if [ "$http_code" = "200" ]; then
        echo " Done!"
        echo ""
        # Parse model list from response - extract model names
        # Filter for coding-related models: qwen, glm, kimi, minimax
        model_list=$(echo "$body" | grep -o '"model":"[^"]*"' | sed 's/"model":"//;s/"$//' | grep -E '^(qwen|glm|kimi|minimax)' | sort -u)

        if [ -z "$model_list" ]; then
            echo "No coding models found in API response, trying alternative parsing..."
            # Alternative: try to parse data[].id field
            model_list=$(echo "$body" | grep -o '"id":"[^"]*"' | sed 's/"id":"//;s/"$//' | grep -E '^(qwen|glm|kimi|minimax)' | sort -u)
        fi
    else
        echo ""
        echo "Note: API request failed (HTTP $http_code) - this is normal if using Coding Plan API key"
        echo "Using predefined model list from Coding Plan documentation..."
    fi

    if [ -z "$model_list" ]; then
        # If API doesn't return models, use predefined list based on documentation
        model_list="qwen3.5-plus
qwen3-max-2026-01-23
qwen3-coder-next
qwen3-coder-plus
glm-5
glm-4.7
kimi-k2.5
minimax-m2.5"
    fi

    local models=()
    while IFS= read -r model; do
        [ -n "$model" ] && models+=("$model")
    done <<< "$model_list"

    local count=${#models[@]}

    if [ "$count" -eq 0 ]; then
        echo "Error: No models available"
        exit 1
    fi

    echo "Available Models:"
    echo ""
    local i=1
    for model in "${models[@]}"; do
        printf "  %2d) %s\n" "$i" "$model"
        ((i++))
    done
    echo ""

    read -p "Select main model [1-$count]: " main_idx
    if ! [[ "$main_idx" =~ ^[0-9]+$ ]] || [ "$main_idx" -lt 1 ] || [ "$main_idx" -gt "$count" ]; then
        echo "Error: Invalid selection"
        exit 1
    fi
    local main_model="${models[$main_idx-1]}"

    read -p "Select fast model [1-$count] (default: same as main): " fast_idx
    local fast_model
    if [ -z "$fast_idx" ]; then
        fast_model="$main_model"
    elif [[ "$fast_idx" =~ ^[0-9]+$ ]] && [ "$fast_idx" -ge 1 ] && [ "$fast_idx" -le "$count" ]; then
        fast_model="${models[$fast_idx-1]}"
    else
        echo "Error: Invalid selection"
        exit 1
    fi

    local model_name="Alibaba Coding Plan ($main_model)"

    save_model_config "$model_name" "https://coding.dashscope.aliyuncs.com/apps/anthropic" "$api_key" "$main_model" "$fast_model"
}

add_manual_model() {
    local preset_command="${1:-}"
    echo ""
    echo "═══════════════════════════════════════"
    if [ -n "$preset_command" ]; then
        echo "  Manual Configuration ($preset_command)"
    else
        echo "  Manual Configuration"
    fi
    echo "═══════════════════════════════════════"
    echo ""
    
    read -p "Model name (e.g., 'GPT-4'): " model_name
    [ -z "$model_name" ] && echo "Error: Name is required" && exit 1

    local command_name="$preset_command"
    if [ -z "$command_name" ]; then
        read -p "Command (default: claude, e.g., claude/codex): " command_name
        [ -z "$command_name" ] && command_name="claude"
    fi
    
    echo ""
    echo "API Configuration:"
    read -p "API Base URL: " base_url
    [ -z "$base_url" ] && echo "Error: Base URL is required" && exit 1
    
    read -p "API Key: " api_key
    [ -z "$api_key" ] && echo "Error: API Key is required" && exit 1
    
    read -p "Main Model (e.g., 'gpt-4' or 'o3'): " main_model
    [ -z "$main_model" ] && echo "Error: Model name is required" && exit 1
    
    local fast_model=""
    if [ "$command_name" != "codex" ]; then
        read -p "Fast Model (optional, press Enter to use main model): " fast_model
        [ -z "$fast_model" ] && fast_model="$main_model"
    fi
    
    save_model_config "$model_name" "$base_url" "$api_key" "$main_model" "$fast_model" "$command_name"
}

save_model_config() {
    local model_name="$1"
    local base_url="$2"
    local api_key="$3"
    local main_model="$4"
    local fast_model="$5"
    local command_name="${6:-claude}"
    local base_url_key=$(get_command_base_url_key "$command_name")
    local api_key_key=$(get_command_api_key_key "$command_name")
    local main_model_key=$(get_command_main_model_key "$command_name")
    local fast_model_key=$(get_command_fast_model_key "$command_name")
    
    local temp_file="${CONFIG_FILE}.tmp.$$"
    
    if command -v jq &> /dev/null; then
        local new_entry=$(jq -n \
            --arg name "$model_name" \
            --arg command_name "$command_name" \
            --arg base_url_key "$base_url_key" \
            --arg api_key_key "$api_key_key" \
            --arg main_model_key "$main_model_key" \
            --arg fast_model_key "$fast_model_key" \
            --arg base_url "$base_url" \
            --arg api_key "$api_key" \
            --arg main_model "$main_model" \
            --arg fast_model "$fast_model" '
                {
                    name: $name,
                    env: {
                        ($base_url_key): $base_url,
                        ($api_key_key): $api_key,
                        ($main_model_key): $main_model
                    }
                }
                | if $fast_model != "" then .env[$fast_model_key] = $fast_model else . end
                | if $command_name != "claude" then .command = $command_name else . end
            ')
        
        if [ ! -s "$CONFIG_FILE" ] || [ "$(cat "$CONFIG_FILE" | tr -d '[:space:]')" = "[]" ]; then
            echo "[$new_entry]" | jq '.' > "$temp_file"
        else
            jq ". += [$new_entry]" "$CONFIG_FILE" > "$temp_file"
        fi
        
        if [ $? -eq 0 ]; then
            mv "$temp_file" "$CONFIG_FILE"
        else
            rm -f "$temp_file"
            echo "Error: Failed to update configuration with jq" >&2
            exit 1
        fi
    else
        local command_json=""
        if [ "$command_name" != "claude" ]; then
            command_json="        \"command\": \"$command_name\","
        fi

        local fast_model_json=""
        if [ -n "$fast_model" ]; then
            fast_model_json=$(cat <<EOF
,
            "$fast_model_key": "$fast_model"
EOF
)
        fi

        local new_entry=$(cat <<EOF
    {
        "name": "$model_name",
${command_json}
        "env": {
            "$base_url_key": "$base_url",
            "$api_key_key": "$api_key",
            "$main_model_key": "$main_model"${fast_model_json}
        }
    }
EOF
)
        
        if [ ! -s "$CONFIG_FILE" ] || [ "$(cat "$CONFIG_FILE" | tr -d '[:space:]')" = "[]" ]; then
            echo "[$new_entry]" > "$CONFIG_FILE"
        else
            local backup="${CONFIG_FILE}.bak"
            cp "$CONFIG_FILE" "$backup"
            
            head -n -1 "$CONFIG_FILE" > "$temp_file"
            echo "," >> "$temp_file"
            echo "$new_entry" >> "$temp_file"
            echo "]" >> "$temp_file"
            
            if [ $? -eq 0 ] && [ -s "$temp_file" ]; then
                mv "$temp_file" "$CONFIG_FILE"
                rm -f "$backup"
            else
                mv "$backup" "$CONFIG_FILE"
                rm -f "$temp_file"
                echo "Error: Failed to update configuration" >&2
                exit 1
            fi
        fi
    fi
    
    echo ""
    echo "✓ Model '$model_name' added successfully!"
    echo ""
    echo "Configuration saved to: $CONFIG_FILE"
}

delete_model() {
    local index=$1
    
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "Error: Config file not found at $CONFIG_FILE"
        exit 1
    fi
    
    local count=$(get_model_count)
    
    case "$index" in
        ''|*[!0-9]*)
            echo "Error: Invalid model index. Must be a number."
            exit 1
            ;;
    esac
    
    if [ "$index" -lt 1 ] || [ "$index" -gt "$count" ]; then
        echo "Error: Invalid model index. Must be between 1 and $count"
        exit 1
    fi
    
    local model_name=$(get_model_name "$index")
    
    echo "═══════════════════════════════════════"
    echo "  Delete Model Configuration"
    echo "═══════════════════════════════════════"
    echo ""
    echo "  Model to delete: $index) $model_name"
    echo ""
    read -p "Are you sure? (y/N): " confirm
    
    case "$confirm" in
        y|Y|yes|YES)
            ;;
        *)
            echo "Cancelled."
            exit 0
            ;;
    esac
    
    local temp_file="${CONFIG_FILE}.tmp"
    local line_num=0
    local in_target=0
    local brace_count=0
    local skipped=0
    
    while IFS= read -r line; do
        line_num=$((line_num + 1))
        
        if echo "$line" | grep -q '"name"'; then
            local current_name=$(echo "$line" | sed 's/.*"name": *"\([^"]*\)".*/\1/')
            if [ "$current_name" = "$model_name" ]; then
                in_target=1
            fi
        fi
        
        if [ $in_target -eq 1 ]; then
            brace_count=$((brace_count + $(echo "$line" | grep -o '{' | wc -l)))
            brace_count=$((brace_count - $(echo "$line" | grep -o '}' | wc -l)))
            
            if [ $brace_count -le 0 ]; then
                in_target=0
                skipped=1
            fi
            continue
        fi
        
        echo "$line" >> "$temp_file"
    done < "$CONFIG_FILE"
    
    if [ $skipped -eq 1 ]; then
        local content=$(cat "$temp_file")
        content=$(echo "$content" | sed 's/},\s*]/}/' | sed 's/,\s*,/,/g')
        echo "$content" > "$temp_file"
    fi
    
    mv "$temp_file" "$CONFIG_FILE"
    
    echo ""
    echo "✓ Model '$model_name' deleted successfully!"
    echo ""
    echo "Remaining models:"
    list_models
}

show_keys() {
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "Error: Config file not found at $CONFIG_FILE"
        exit 1
    fi

    echo "═══════════════════════════════════════"
    echo "  API Keys Overview"
    echo "═══════════════════════════════════════"
    echo ""

    local index=1
    if command -v jq &> /dev/null; then
        while IFS=$'\t' read -r current_name command_name current_url current_key; do
            [ -z "$current_name" ] && continue

            local key_len=${#current_key}
            local masked_key
            if [ $key_len -gt 12 ]; then
                masked_key="${current_key:0:8}...${current_key: -4}"
            else
                masked_key="${current_key:0:4}***"
            fi

            printf "%d) \033[1;36m%s\033[0m\n" "$index" "$current_name"
            printf "   Command: %s\n" "$command_name"
            printf "   URL: %s\n" "$current_url"
            printf "   Key: \033[0;90m%s\033[0m\n\n" "$masked_key"
            ((index++))
        done < <(jq -r '.[] | select(.name and .env) | [
            (.name // ""),
            (.command // "claude"),
            (.env.ANTHROPIC_BASE_URL // .env.OPENAI_BASE_URL // ""),
            (.env.ANTHROPIC_AUTH_TOKEN // .env.OPENAI_API_KEY // "")
        ] | @tsv' "$CONFIG_FILE")
    else
        local current_name=""
        local command_name="claude"
        local current_url=""
        local current_key=""

        while IFS= read -r line; do
            if echo "$line" | grep -q '"name"'; then
                current_name=$(echo "$line" | sed 's/.*"name": *"\([^"]*\)".*/\1/')
                command_name="claude"
                current_url=""
                current_key=""
            fi

            if echo "$line" | grep -q '"command"'; then
                command_name=$(echo "$line" | sed 's/.*"command": *"\([^"]*\)".*/\1/')
            fi

            if echo "$line" | grep -q '"ANTHROPIC_BASE_URL"\|"OPENAI_BASE_URL"'; then
                current_url=$(echo "$line" | sed 's/.*": *"\([^"]*\)".*/\1/')
            fi

            if echo "$line" | grep -q '"ANTHROPIC_AUTH_TOKEN"\|"OPENAI_API_KEY"'; then
                current_key=$(echo "$line" | sed 's/.*": *"\([^"]*\)".*/\1/')
                local key_len=${#current_key}
                local masked_key
                if [ $key_len -gt 12 ]; then
                    masked_key="${current_key:0:8}...${current_key: -4}"
                else
                    masked_key="${current_key:0:4}***"
                fi

                printf "%d) \033[1;36m%s\033[0m\n" "$index" "$current_name"
                printf "   Command: %s\n" "$command_name"
                printf "   URL: %s\n" "$current_url"
                printf "   Key: \033[0;90m%s\033[0m\n\n" "$masked_key"
                ((index++))
            fi
        done < "$CONFIG_FILE"
    fi

    echo "───────────────────────────────────────"
    echo ""
    echo "To edit keys: ccc -E"
    echo "To add model: ccc -a"
}

update_claude_settings() {
    local main_model="$1"
    local fast_model="$2"

    # Create .claude directory if it doesn't exist
    mkdir -p "$HOME/.claude"

    local settings_temp="${CLAUDE_SETTINGS_FILE}.tmp"

    if command -v jq &> /dev/null; then
        # Use jq if available
        if [ -f "$CLAUDE_SETTINGS_FILE" ]; then
            # Update existing settings
            # Disable built-in subagents (Explore uses hard-coded Haiku which may not be supported)
            # Set model field to override default model for all agents including subagents
            jq --arg main "$main_model" --arg fast "$fast_model" '
                .env = (.env // {}) |
                .env.ANTHROPIC_MODEL = $main |
                .env.ANTHROPIC_SMALL_FAST_MODEL = $fast |
                .env.CLAUDE_CODE_MODEL = $main |
                .env.CLAUDE_CODE_SMALL_MODEL = $fast |
                .env.CLAUDE_CODE_SUBAGENT_MODEL = $main |
                .model = $main |
                .permissions = (.permissions // {}) |
                .permissions.deny = ((.permissions.deny // []) + ["Agent(Explore)"] | unique)
            ' "$CLAUDE_SETTINGS_FILE" > "$settings_temp" 2>/dev/null

            if [ $? -eq 0 ]; then
                mv "$settings_temp" "$CLAUDE_SETTINGS_FILE"
            else
                rm -f "$settings_temp"
                # If jq failed, create new settings
                create_default_settings "$main_model" "$fast_model"
            fi
        else
            # Create new settings
            create_default_settings "$main_model" "$fast_model"
        fi
    else
        # Fallback without jq
        create_default_settings "$main_model" "$fast_model"
    fi
}

create_default_settings() {
    local main_model="$1"
    local fast_model="$2"

    cat > "$CLAUDE_SETTINGS_FILE" <<EOF
{
  "env": {
    "ANTHROPIC_MODEL": "$main_model",
    "ANTHROPIC_SMALL_FAST_MODEL": "$fast_model",
    "CLAUDE_CODE_MODEL": "$main_model",
    "CLAUDE_CODE_SMALL_MODEL": "$fast_model",
    "CLAUDE_CODE_SUBAGENT_MODEL": "$main_model"
  },
  "model": "$main_model",
  "permissions": {
    "deny": ["Agent(Explore)"]
  }
}
EOF
}

update_codex_config() {
    local base_url="$1"
    local model="$2"

    mkdir -p "$HOME/.codex"

    local temp_file="${CODEX_CONFIG_FILE}.tmp"
    if [ ! -f "$CODEX_CONFIG_FILE" ]; then
        cat > "$CODEX_CONFIG_FILE" <<EOF
model_provider = "codex"
model = "$model"
model_reasoning_effort = "high"
disable_response_storage = true

[model_providers.codex]
name = "codex"
base_url = "$base_url"
wire_api = "responses"
EOF
        return
    fi

    awk -v url="$base_url" -v model="$model" '
        function emit_top_level_defaults() {
            if (!top_provider_seen) print "model_provider = \"codex\""
            if (!top_model_seen) print "model = \"" model "\""
        }
        function emit_codex_defaults() {
            if (in_codex) {
                if (!codex_name_seen) print "name = \"codex\""
                if (!codex_base_seen) print "base_url = \"" url "\""
                if (!codex_wire_seen) print "wire_api = \"responses\""
            }
        }
        /^\[[^]]+\]/ {
            if (!saw_section) {
                emit_top_level_defaults()
                saw_section = 1
            }
            emit_codex_defaults()
            current_section = substr($0, 2, length($0) - 2)
            in_codex = (current_section == "model_providers.codex")
            if (in_codex) {
                section_seen = 1
                codex_name_seen = 0
                codex_base_seen = 0
                codex_wire_seen = 0
            }
            print
            next
        }
        {
            if (current_section == "") {
                if ($0 ~ /^model_provider[[:space:]]*=/) {
                    print "model_provider = \"codex\""
                    top_provider_seen = 1
                    next
                }
                if ($0 ~ /^model[[:space:]]*=/) {
                    print "model = \"" model "\""
                    top_model_seen = 1
                    next
                }
                if ($0 ~ /^openai_base_url[[:space:]]*=/) {
                    next
                }
                print
                next
            }
            if (in_codex) {
                if ($0 ~ /^name[[:space:]]*=/) {
                    print "name = \"codex\""
                    codex_name_seen = 1
                    next
                }
                if ($0 ~ /^base_url[[:space:]]*=/) {
                    print "base_url = \"" url "\""
                    codex_base_seen = 1
                    next
                }
                if ($0 ~ /^wire_api[[:space:]]*=/) {
                    print "wire_api = \"responses\""
                    codex_wire_seen = 1
                    next
                }
            }
            print
        }
        END {
            if (!saw_section) {
                emit_top_level_defaults()
            }
            emit_codex_defaults()
            if (!section_seen) {
                if (NR > 0) print ""
                print "[model_providers.codex]"
                print "name = \"codex\""
                print "base_url = \"" url "\""
                print "wire_api = \"responses\""
            }
        }
    ' "$CODEX_CONFIG_FILE" > "$temp_file" && mv "$temp_file" "$CODEX_CONFIG_FILE"
}

update_codex_auth() {
    local api_key="$1"

    mkdir -p "$HOME/.codex"

    if command -v jq &> /dev/null && [ -f "$CODEX_AUTH_FILE" ]; then
        jq --arg api_key "$api_key" '.OPENAI_API_KEY = $api_key' "$CODEX_AUTH_FILE" > "${CODEX_AUTH_FILE}.tmp" 2>/dev/null \
            && mv "${CODEX_AUTH_FILE}.tmp" "$CODEX_AUTH_FILE" \
            && chmod 600 "$CODEX_AUTH_FILE"
        if [ $? -eq 0 ]; then
            return
        fi
    fi

    cat > "$CODEX_AUTH_FILE" <<EOF
{
  "OPENAI_API_KEY": "$api_key"
}
EOF
    chmod 600 "$CODEX_AUTH_FILE"
}

skip_perm=false
only_env=false
model_index=""
claude_args=()

while [ $# -gt 0 ]; do
    case $1 in
        -y|--bypass)
            skip_perm=true
            shift
            ;;
        -e|--env)
            only_env=true
            shift
            ;;
        --edit)
            edit_config
            exit 0
            ;;
        -a|--add)
            add_model
            exit 0
            ;;
        -d|--delete)
            if [ -z "$2" ]; then
                echo "Error: --delete requires a model index"
                exit 1
            fi
            delete_model "$2"
            exit 0
            ;;
        -s|--show)
            show_keys
            exit 0
            ;;
        --validate)
            validate_config
            exit 0
            ;;
        -U|--upgrade)
            upgrade
            exit 0
            ;;
        -V|--version)
            show_version
            exit 0
            ;;
        --uninstall)
            shift
            uninstall_cc "$@"
            exit 0
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            claude_args=("$@")
            break
            ;;
        [0-9]*)
            model_index=$1
            shift
            ;;
        *)
            echo "Unknown option: $1"
            usage
            exit 1
            ;;
    esac
done

run_with_model "$model_index" "$skip_perm" "$only_env" "${claude_args[@]}"
