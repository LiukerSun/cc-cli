#!/usr/bin/env bash

set -euo pipefail

SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

warn_legacy() {
    printf '%s\n' "Warning: bin/ccc is now a legacy compatibility wrapper. Install and use the Go binary instead." >&2
}

find_target() {
    local candidate resolved
    for candidate in \
        "$HOME/.local/bin/ccc" \
        "$HOME/bin/ccc" \
        "/usr/local/bin/ccc" \
        "$REPO_ROOT/ccc"
    do
        if [ -x "$candidate" ]; then
            resolved="$(cd "$(dirname "$candidate")" && pwd)/$(basename "$candidate")"
            if [ "$resolved" != "$SCRIPT_PATH" ]; then
                printf '%s\n' "$candidate"
                return 0
            fi
        fi
    done
    return 1
}

if target="$(find_target)"; then
    warn_legacy
    exec "$target" "$@"
fi

cat >&2 <<'EOF'
Error: no installed Go-based ccc binary was found.

Install cc-cli:
  curl -fsSL https://raw.githubusercontent.com/LiukerSun/cc-cli/main/install.sh | bash

Or build it locally from this repository:
  go build -o ~/.local/bin/ccc ./cmd/ccc
EOF
exit 1
